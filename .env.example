# ── Antigravity via opencode subprocess (recommended) ─────────────────────────
# Requires: opencode CLI + opencode-antigravity-auth plugin (see deps/).
# Model spec format: "model:variant" — variant is passed as --variant to opencode run.
# delegate.mjs tries each model left-to-right; falls back on quota exhaustion.

DELEGATE_RUNNER=opencode

# --type=code (default): Opus:max for best coding quality → Flash:high fallback on quota
GCLI_MODELS_CODE=google/antigravity-claude-opus-4-6-thinking:max,google/antigravity-gemini-3.5-flash:high

# --type=lookup: Flash:high directly (no Opus needed for extraction tasks)
GCLI_MODELS_LOOKUP=google/antigravity-gemini-3.5-flash:high

# ── Debug / logging ───────────────────────────────────────────────────────────
# Logs always written to logs/delegate-{agent}.log inside the project (gitignored).
# Agent auto-detected from env; set explicitly if auto-detect misses:
# DELEGATE_AGENT=claude        # or codex, opencode, default
# DELEGATE_DEBUG=1             # verbose DEBUG lines on stderr + log file
# DELEGATE_LOG_FILE=C:\custom\path.log   # override default log path

# ── Legacy HTTP mode (OpenAI-compatible proxy) ─────────────────────────────────
# Used when DELEGATE_RUNNER is not set.
# Pool format: comma-separated "key:weight" (weight optional, defaults to 1).
# GCLI_API_KEY=key_aaa:3,key_bbb:1
# GCLI_BASE_URL=https://your-openai-compatible-proxy/v1
# GCLI_MODEL=gemini-3.1-pro
# GCLI_MAX_RETRIES=4
# GCLI_TIMEOUT_MS=30000
